# ============================================================
# ОБЩИЕ НАСТРОЙКИ
# ============================================================
APP_ENV=production
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_TIMEZONE=Europe/Moscow
APP_BASE_URL=https://your-domain.example.com

# ============================================================
# БАЗА ДАННЫХ
# По умолчанию SQLite (для старта). Для перехода на PostgreSQL
# достаточно поменять DATABASE_URL — код не меняется.
# SQLite:      sqlite+aiosqlite:///./data/db.sqlite3
# PostgreSQL:  postgresql+asyncpg://user:password@postgres:5432/raffle
# ============================================================
DATABASE_URL=sqlite+aiosqlite:///./data/db.sqlite3

# ============================================================
# JWT (веб-панель администратора)
# ============================================================
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# ============================================================
# ВКЛЮЧЕНИЕ/ВЫКЛЮЧЕНИЕ ИНТЕГРАЦИЙ
# ============================================================
# Docker Compose profiles — решают, запускается ли контейнер бота ВООБЩЕ.
# Только Telegram (VK-бот не собирается и не запускается):
COMPOSE_PROFILES=telegram
# Когда будете подключать VK: COMPOSE_PROFILES=telegram,vk

# ============================================================
# TELEGRAM BOT
# ============================================================
# Общий выключатель (вторая линия защиты после COMPOSE_PROFILES — см. выше):
# если false, процесс бота запускается, но к Telegram не подключается.
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456:AAAA-your-telegram-bot-token

# Прокси для связи бота с api.telegram.org — заполните, если сервер не
# имеет прямого доступа к Telegram (блокировки, санкции хостинга и т.п.).
# Поддерживаются HTTP(S) и SOCKS5, с авторизацией или без:
#   TELEGRAM_PROXY_URL=http://user:password@proxy.example.com:8080
#   TELEGRAM_PROXY_URL=socks5://user:password@proxy.example.com:1080
# Оставьте пустым, если прокси не нужен.
TELEGRAM_PROXY_URL=

# ============================================================
# VK BOT
# Пока не подключаем — см. COMPOSE_PROFILES и VK_ENABLED выше/ниже.
# Можно оставить поля как есть до момента реального подключения VK.
# ============================================================
VK_ENABLED=false
VK_GROUP_TOKEN=vk1.a.your-group-token
VK_GROUP_ID=123456789

# Прокси для VK API (обычно не требуется — VK не блокируется в РФ,
# но опция поддержана на случай ограничений исходящего трафика хостинга).
VK_PROXY_URL=

# ============================================================
# ПЛАТЁЖНЫЙ ПРОВАЙДЕР
# Один параметр переключает эквайринг без изменения кода.
# Допустимые значения: tbank | vtb
# ============================================================
PAYMENT_PROVIDER=tbank

# --- Т-Банк эквайринг ---
TBANK_TERMINAL_KEY=TinkoffBankTest
TBANK_SECRET_KEY=your-tbank-secret-key
TBANK_API_URL=https://securepay.tinkoff.ru/v2

# --- ВТБ эквайринг ---
VTB_MERCHANT_ID=your-vtb-merchant-id
VTB_SECRET_KEY=your-vtb-secret-key
VTB_API_URL=https://api.vtb.ru/acquiring/v1

# ============================================================
# АДМИН-ПАНЕЛЬ (первичный Super Admin, создаётся один раз
# скриптом scripts/create_superadmin.py)
# ============================================================
INITIAL_SUPERADMIN_LOGIN=superadmin
INITIAL_SUPERADMIN_PASSWORD=change-me-strong-password

# ============================================================
# CORS (адрес фронтенда админ-панели)
# Если настроен reverse-proxy с доменом (см. ниже DOMAIN) — добавьте сюда
# https://ваш-домен, т.к. именно с этого origin браузер будет обращаться
# к API после того, как всё пойдёт через Caddy.
# ============================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ============================================================
# REVERSE-PROXY / TLS (Caddy, см. docker/Caddyfile)
# ============================================================
# Домен, на который смотрит DNS этого сервера. Порты 80/443 должны быть
# открыты наружу — Caddy сам получит и будет продлевать сертификат
# Let's Encrypt. Если оставить localhost (значение по умолчанию) — Caddy
# выпустит локальный self-signed сертификат для разработки/тестов.
DOMAIN=localhost
# Email для Let's Encrypt (уведомления об истечении сертификата и т.п.).
LETSENCRYPT_EMAIL=admin@example.com

# ============================================================
# РЕЗЕРВНОЕ КОПИРОВАНИЕ БД (scripts/backup_db.sh, см. docs/BACKUP.md)
# ============================================================
# Куда складывать бэкапы (на хосте, вне docker volume — том с БД может быть
# потерян вместе с бэкапами, если хранить их там же).
BACKUP_DIR=./backups
# Сколько дней хранить бэкапы, старые удаляются автоматически.
BACKUP_RETENTION_DAYS=14

# ============================================================
# АВТООБНОВЛЕНИЕ ИЗ GIT (scripts/auto_update.sh, см. docs/AUTO_UPDATE.md)
# ============================================================
AUTO_UPDATE_BRANCH=main
# Ваш личный chat_id в Telegram для уведомлений об обновлениях (необязательно).
# Узнать: напишите @userinfobot в Telegram.
AUTO_UPDATE_NOTIFY_CHAT_ID=
